parameters:
	level: 8

	paths:
		- src

	excludePaths:
		# PHPUnit is an optional peer dependency; its types resolve only when running under PHPUnit
		- src/PHPUnitExtension.php

	ignoreErrors:
		-   # Intentional keep-alive container: retains proc_open handles so PHP won't close them (see #43)
			identifier: property.onlyWritten
			count: 1
			path: src/NativeWrapper.php

		-   # Lock operation is constrained to valid values by PHP's stream-wrapper protocol; the int<0,7> stub range cannot be proven from the plain int parameter
			message: '#Parameter \#2 \$operation of function flock expects int<0, 7>#'
			count: 1
			path: src/NativeWrapper.php

		-   # Read length is always positive when supplied by PHP's stream layer; the int<1,max> stub range cannot be proven from the plain int parameter
			message: '#Parameter \#2 \$length of function fread expects int<1, max>#'
			count: 1
			path: src/NativeWrapper.php

		-   # Truncation size is non-negative by PHP's stream-wrapper protocol; the int<0,max> stub range cannot be proven from the plain int parameter
			message: '#Parameter \#2 \$size of function ftruncate expects int<0, max>#'
			count: 1
			path: src/NativeWrapper.php

		-   # native() polymorphically invokes various native functions (fopen, touch, chown, ...) with differing signatures; a single callable signature cannot describe them
			identifier: missingType.callable
			count: 1
			path: src/NativeWrapper.php

		-   # $context is declared via @property on the StreamWrapper interface; PHPStan does not honor @property on interfaces
			message: '#Access to an undefined property DG\\BypassFinals\\StreamWrapper::\$context#'
			count: 1
			path: src/MutatingWrapper.php
